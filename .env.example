APP_ENV=dev
APP_NAME=day13-observability-lab
LOG_LEVEL=INFO
LOG_PATH=data/logs.jsonl
AUDIT_LOG_PATH=data/audit.jsonl
# Model cho LabAgent (FakeLLM) và log — đổi tên model tại đây
MODEL_NAME=claude-sonnet-4-5
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# SDK Langfuse Python đọc LANGFUSE_HOST (mặc định đã là cloud)
LANGFUSE_HOST=https://cloud.langfuse.com
